{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Akatsuki Cloud Habit Tracker",
  "version": "0.1.0",
  "identifier": "com.akatsuki.cloudhabittracker",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "habit-panel",
        "title": "Akatsuki Habits",
        "width": 400,
        "height": 360,
        "minWidth": 360,
        "minHeight": 300,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "visible": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
